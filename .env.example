# Credenciais do Supabase para a versão Vite/React.
# Copie para `.env.local` (ignorado pelo git) e preencha com os valores reais.
# A anon key é pública (de cliente); obtenha via:
#   npx supabase projects api-keys --project-ref <project-ref> -o json  (campo name == 'anon')
VITE_SUPABASE_URL=https://<project-ref>.supabase.co
VITE_SUPABASE_ANON_KEY=<anon-public-key>
